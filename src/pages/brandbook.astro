---
import Layout from '../layouts/Layout.astro';

const { title = "Brandbook — Icónico", description = "Design tokens y sistema visual de Icónico." } = Astro.props;
---

<style>
  .bb { background-color: #F3EEE6; color: #1F1F1D; }

  .bb-section { padding: 5rem 1.5rem; max-width: 80rem; margin: 0 auto; }
  .bb-section + .bb-section { border-top: 1px solid #E4D8C8; }

  .bb-eyebrow {
    font-size: 0.6875rem; letter-spacing: 0.3em; text-transform: uppercase;
    color: #4A3525; font-weight: 500; margin-bottom: 1.5rem;
  }
  .bb-h1 {
    font-family: 'Playfair Display', serif; font-weight: 700;
    font-size: clamp(2.5rem, 6vw, 4.5rem); letter-spacing: -0.03em;
    line-height: 1.05; margin-bottom: 1.5rem;
  }
  .bb-h2 {
    font-family: 'Playfair Display', serif; font-weight: 600;
    font-size: clamp(1.75rem, 3.5vw, 2.5rem); letter-spacing: -0.02em;
    line-height: 1.15; margin-bottom: 1rem;
  }
  .bb-lead { font-size: 1.125rem; line-height: 1.6; color: #1F1F1D; max-width: 48rem; }

  .bb-grid { display: grid; gap: 1.5rem; margin-top: 3rem; }
  .bb-grid-cols-2 { grid-template-columns: repeat(auto-fit, minmax(18rem, 1fr)); }
  .bb-grid-cols-3 { grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr)); }

  .swatch {
    border-radius: 1rem; overflow: hidden;
    border: 1px solid #E4D8C8; background: #fff;
    transition: transform 200ms cubic-bezier(0.4, 0, 0.2, 1);
  }
  .swatch:hover { transform: translateY(-2px); }
  .swatch-color { aspect-ratio: 4/3; }
  .swatch-info { padding: 1.25rem; }
  .swatch-name { font-weight: 600; font-size: 1rem; margin-bottom: 0.25rem; }
  .swatch-hex { font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 0.875rem; color: #1F1F1D; }
  .swatch-rgb { font-size: 0.75rem; color: rgba(31, 31, 29, 0.55); margin-top: 0.25rem; }
  .swatch-use {
    font-size: 0.75rem; line-height: 1.5;
    color: rgba(31, 31, 29, 0.65); margin-top: 0.75rem;
    padding-top: 0.75rem; border-top: 1px solid #E4D8C8;
  }

  .ratio {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.6875rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: #1F1F1D; font-weight: 500;
  }
  .ratio-pass { color: #1F3829; }
  .ratio-fail { color: #b94a2e; }
  .ratio-dot { width: 0.5rem; height: 0.5rem; border-radius: 9999px; background: currentColor; }

  .type-card {
    background: #fff; border: 1px solid #E4D8C8; border-radius: 1rem;
    padding: 2rem; display: flex; flex-direction: column; gap: 1rem;
  }
  .type-label {
    font-size: 0.6875rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: #4A3525; font-weight: 500;
  }
  .type-display { font-family: 'Playfair Display', serif; line-height: 1; }
  .type-body { font-family: 'Inter', sans-serif; line-height: 1.5; }

  .pill {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: rgba(31, 43, 56, 0.06); color: #1F2B38;
    padding: 0.375rem 0.75rem; border-radius: 9999px;
    font-size: 0.75rem; font-weight: 500;
  }
  .pill-success { background: rgba(31, 56, 41, 0.08); color: #1F3829; }
  .pill-warn { background: rgba(185, 74, 46, 0.08); color: #b94a2e; }

  .dist-bar {
    height: 28px; border-radius: 9999px; overflow: hidden;
    display: flex; background: #E4D8C8;
  }
  .dist-segment { height: 100%; display: flex; align-items: center; justify-content: center; font-size: 0.6875rem; font-weight: 600; color: #1F1F1D; }

  .specimen-bg-cream { background: #F3EEE6; }
  .specimen-bg-sand { background: #E4D8C8; }
  .specimen-bg-navy { background: #1F2B38; color: #F3EEE6; }
  .specimen-bg-forest { background: #1F3829; color: #F3EEE6; }
  .specimen-bg-coffee { background: #4A3525; color: #F3EEE6; }
  .specimen-bg-charcoal { background: #1F1F1D; color: #F3EEE6; }

  .token-row {
    display: grid; grid-template-columns: 12rem 1fr auto;
    gap: 1rem; padding: 0.75rem 0;
    border-bottom: 1px solid rgba(31, 31, 29, 0.08);
    font-family: 'JetBrains Mono', ui-monospace, monospace; font-size: 0.8125rem;
  }
  .token-name { color: #1F2B38; font-weight: 600; }
  .token-value { color: #1F1F1D; }
  .token-type {
    font-size: 0.625rem; padding: 0.125rem 0.5rem; border-radius: 9999px;
    background: rgba(31, 43, 56, 0.08); color: #1F2B38;
    letter-spacing: 0.1em; text-transform: uppercase;
  }

  .checklist { list-style: none; padding: 0; margin: 0; display: grid; gap: 0.75rem; }
  .checklist li { display: flex; gap: 0.75rem; align-items: flex-start; }
  .check-icon {
    width: 1.25rem; height: 1.25rem; flex-shrink: 0; margin-top: 0.125rem;
    border-radius: 9999px; display: flex; align-items: center; justify-content: center;
    font-size: 0.75rem; line-height: 1;
  }
  .check-ok { background: #1F3829; color: #F3EEE6; }
  .check-no { background: #b94a2e; color: #F3EEE6; }

  @media (max-width: 640px) {
    .bb-section { padding: 3rem 1.25rem; }
    .token-row { grid-template-columns: 1fr; gap: 0.25rem; }
  }
</style>

<Layout title={title} description={description}>
<main class="bb">

  <!-- HERO -->
  <section class="bb-section">
    <div class="bb-eyebrow">Brand Identity · Design System v1</div>
    <h1 class="bb-h1">Icónico</h1>
    <p class="bb-lead">
      Specialty Coffee, Made Simple. Sistema visual completo: paleta editorial,
      tipografía de contraste, spacing consistente y motion calmado.
    </p>
    <div class="flex flex-wrap gap-2 mt-8">
      <span class="pill">Quiet Premium</span>
      <span class="pill">Scandinavian</span>
      <span class="pill">Japanese Minimalism</span>
      <span class="pill">Editorial Design</span>
      <span class="pill">Natural Materials</span>
    </div>
  </section>

  <!-- COLOR PALETTE -->
  <section class="bb-section">
    <div class="bb-eyebrow">Color Palette · 6 core + 1 extended</div>
    <h2 class="bb-h2">Paleta editorial</h2>
    <p class="text-base leading-relaxed max-w-2xl" style="color: rgba(31, 31, 29, 0.7);">
      Neutros cálidos como base (80%), navy como acento premium (10%),
      coffee y sage como detalles sensoriales (5% cada uno). Forest es
      el verde activo usado en hovers y modo experto de la tienda.
    </p>

    <div class="dist-bar mt-8 mb-12">
      <div class="dist-segment specimen-bg-cream" style="width: 80%;">80% Cream</div>
      <div class="dist-segment specimen-bg-navy" style="width: 10%; color: #F3EEE6;">10% Navy</div>
      <div class="dist-segment specimen-bg-coffee" style="width: 5%; color: #F3EEE6;">5% Coffee</div>
      <div class="dist-segment specimen-bg-sage" style="width: 5%; color: #F3EEE6;">5% Sage</div>
    </div>

    <div class="bb-grid bb-grid-cols-3">
      <article class="swatch">
        <div class="swatch-color specimen-bg-cream" style="border-bottom: 1px solid #E4D8C8;"></div>
        <div class="swatch-info">
          <div class="swatch-name">Cream</div>
          <div class="swatch-hex">#F3EEE6</div>
          <div class="swatch-rgb">rgb(243, 238, 230)</div>
          <div class="swatch-use"><strong>Uso:</strong> Fondo principal del sitio, etiquetas, secciones. La base editorial.</div>
        </div>
      </article>

      <article class="swatch">
        <div class="swatch-color specimen-bg-sand"></div>
        <div class="swatch-info">
          <div class="swatch-name">Sand</div>
          <div class="swatch-hex">#E4D8C8</div>
          <div class="swatch-rgb">rgb(228, 216, 200)</div>
          <div class="swatch-use"><strong>Uso:</strong> Fondos secundarios, bordes suaves, hairline dividers, apoyo.</div>
        </div>
      </article>

      <article class="swatch">
        <div class="swatch-color specimen-bg-charcoal"></div>
        <div class="swatch-info">
          <div class="swatch-name">Charcoal</div>
          <div class="swatch-hex">#1F1F1D</div>
          <div class="swatch-rgb">rgb(31, 31, 29)</div>
          <div class="swatch-use"><strong>Uso:</strong> Texto principal, logotipo, máxima jerarquía. Casi negro, no puro.</div>
        </div>
      </article>

      <article class="swatch">
        <div class="swatch-color specimen-bg-navy"></div>
        <div class="swatch-info">
          <div class="swatch-name">Navy</div>
          <div class="swatch-hex">#1F2B38</div>
          <div class="swatch-rgb">rgb(31, 43, 56)</div>
          <div class="swatch-use"><strong>Uso:</strong> Acento premium. Hovers, focus rings, divisores, elementos destacados. 10% del diseño.</div>
        </div>
      </article>

      <article class="swatch">
        <div class="swatch-color specimen-bg-coffee"></div>
        <div class="swatch-info">
          <div class="swatch-name">Coffee</div>
          <div class="swatch-hex">#4A3525</div>
          <div class="swatch-rgb">rgb(74, 53, 37)</div>
          <div class="swatch-use"><strong>Uso:</strong> Iconografía sensorial, detalles de café, eyebrows. 5%.</div>
        </div>
      </article>

      <article class="swatch">
        <div class="swatch-color" style="background: #6B5E4A;"></div>
        <div class="swatch-info">
          <div class="swatch-name">Sage</div>
          <div class="swatch-hex">#6B5E4A</div>
          <div class="swatch-rgb">rgb(107, 94, 74)</div>
          <div class="swatch-use"><strong>Uso:</strong> Detalles naturales, sostenibilidad, acentos secundarios cálidos. 5%.</div>
        </div>
      </article>

      <article class="swatch">
        <div class="swatch-color specimen-bg-forest"></div>
        <div class="swatch-info">
          <div class="swatch-name">Forest <span class="pill-warn pill" style="font-size: 0.625rem;">Extended</span></div>
          <div class="swatch-hex">#1F3829</div>
          <div class="swatch-rgb">rgb(31, 56, 41)</div>
          <div class="swatch-use"><strong>Uso:</strong> Footer, modo experto /tienda, ripple fill de nav, CTAs hover. No está en MASTER.md original; agregado en implementación.</div>
        </div>
      </article>
    </div>
  </section>

  <!-- COLOR USAGE SPECIMENS -->
  <section class="bb-section">
    <div class="bb-eyebrow">In Context</div>
    <h2 class="bb-h2">Cómo viven los colores en pantalla</h2>
    <p class="text-base leading-relaxed max-w-2xl" style="color: rgba(31, 31, 29, 0.7);">
      Combinaciones validadas. Cream + charcoal es la base. Navy entra como
      acento, nunca como大面积. Forest solo en dark mode (footer, shop experto).
    </p>

    <div class="bb-grid bb-grid-cols-2 mt-8">
      <article class="rounded-2xl overflow-hidden border" style="border-color: #E4D8C8;">
        <div class="p-12 specimen-bg-cream">
          <div class="bb-eyebrow" style="color: #4A3525;">Landing · default</div>
          <div style="font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 700; letter-spacing: -0.03em; line-height: 1; color: #1F1F1D;">Café de especialidad, sin rodeos.</div>
          <div class="mt-6 flex gap-3">
            <button class="px-5 py-2.5 rounded-full text-sm font-medium" style="background: #1F1F1D; color: #F3EEE6;">Comprar ahora</button>
            <button class="px-5 py-2.5 rounded-full text-sm font-medium border" style="border-color: #1F2B38; color: #1F2B38;">Ver suscripción</button>
          </div>
        </div>
        <div class="p-4 text-xs" style="background: #fff; color: rgba(31, 31, 29, 0.6); font-family: ui-monospace, monospace;">
          bg: cream #F3EEE6 · text: charcoal #1F1F1D · accent: navy #1F2B38
        </div>
      </article>

      <article class="rounded-2xl overflow-hidden border" style="border-color: #E4D8C8;">
        <div class="p-12 specimen-bg-navy">
          <div class="bb-eyebrow" style="color: #E4D8C8;">Hover state · nav link</div>
          <div style="font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 700; letter-spacing: -0.03em; line-height: 1; color: #F3EEE6;">Tienda</div>
          <div class="mt-4 text-sm" style="color: #E4D8C8;">Ripple animation · 500ms cubic-bezier(0.4, 0, 0.2, 1)</div>
        </div>
        <div class="p-4 text-xs" style="background: #fff; color: rgba(31, 31, 29, 0.6); font-family: ui-monospace, monospace;">
          bg: navy #1F2B38 · text: cream #F3EEE6 · secondary: sand #E4D8C8
        </div>
      </article>

      <article class="rounded-2xl overflow-hidden border" style="border-color: #E4D8C8;">
        <div class="p-12 specimen-bg-forest">
          <div class="bb-eyebrow" style="color: #E4D8C8;">Footer · dark</div>
          <div style="font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 700; letter-spacing: -0.03em; line-height: 1; color: #F3EEE6;">icónico</div>
          <div class="mt-4 text-sm" style="color: rgba(243, 238, 230, 0.5);">© 2026 · Specialty coffee, made simple.</div>
        </div>
        <div class="p-4 text-xs" style="background: #fff; color: rgba(31, 31, 29, 0.6); font-family: ui-monospace, monospace;">
          bg: forest #1F3829 · text: cream/40
        </div>
      </article>

      <article class="rounded-2xl overflow-hidden border" style="border-color: #E4D8C8;">
        <div class="p-12" style="background: #4A3525;">
          <div class="bb-eyebrow" style="color: #E4D8C8;">Coffee · sensory</div>
          <div style="font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 700; letter-spacing: -0.03em; line-height: 1; color: #F3EEE6;">Notas a chocolate y avellana.</div>
        </div>
        <div class="p-4 text-xs" style="background: #fff; color: rgba(31, 31, 29, 0.6); font-family: ui-monospace, monospace;">
          bg: coffee #4A3525 · text: cream #F3EEE6
        </div>
      </article>
    </div>
  </section>

  <!-- TYPOGRAPHY -->
  <section class="bb-section">
    <div class="bb-eyebrow">Typography</div>
    <h2 class="bb-h2">Playfair Display + Inter</h2>
    <p class="text-base leading-relaxed max-w-2xl" style="color: rgba(31, 31, 29, 0.7);">
      Contraste editorial: serif para jerarquía, sans para cuerpo y UI.
    </p>

    <div class="bb-grid bb-grid-cols-2 mt-8">
      <article class="type-card">
        <div class="type-label">Display · Playfair 700</div>
        <div class="type-display" style="font-size: clamp(3rem, 10vw, 6rem); font-weight: 700; letter-spacing: -0.05em; line-height: 0.95; color: #1F1F1D;">
          Icónico
        </div>
        <div class="text-xs" style="color: rgba(31, 31, 29, 0.55); font-family: ui-monospace, monospace;">
          font-size: clamp(3rem, 10vw, 12rem) · font-weight: 700 · letter-spacing: -0.05em
        </div>
      </article>

      <article class="type-card">
        <div class="type-label">Heading · Playfair 600</div>
        <div class="type-display" style="font-size: 2.25rem; font-weight: 600; letter-spacing: -0.02em; line-height: 1.15; color: #1F1F1D;">
          El café que te entiende
        </div>
        <div class="text-xs" style="color: rgba(31, 31, 29, 0.55); font-family: ui-monospace, monospace;">
          font-size: clamp(1.75rem, 3.5vw, 2.5rem) · font-weight: 600
        </div>
      </article>

      <article class="type-card">
        <div class="type-label">Body · Inter 400</div>
        <div class="type-body" style="font-size: 1rem; color: #1F1F1D; max-width: 32rem;">
          Blend insignia de la casa. Notas a chocolate negro, caramelo y un final
          limpio a avellana tostada. Tueste medio pensado para espresso y filtrados.
        </div>
        <div class="text-xs" style="color: rgba(31, 31, 29, 0.55); font-family: ui-monospace, monospace;">
          font-size: 1rem · line-height: 1.6
        </div>
      </article>

      <article class="type-card">
        <div class="type-label">Eyebrow · Inter 500 tracked</div>
        <div class="type-body" style="font-size: 0.6875rem; font-weight: 500; letter-spacing: 0.3em; text-transform: uppercase; color: #4A3525;">
          El programa Icónico · 10 niveles
        </div>
        <div class="text-xs" style="color: rgba(31, 31, 29, 0.55); font-family: ui-monospace, monospace;">
          font-size: 0.6875rem · letter-spacing: 0.3em · text-transform: uppercase
        </div>
      </article>
    </div>
  </section>

  <!-- TOKENS TABLE -->
  <section class="bb-section">
    <div class="bb-eyebrow">Design Tokens · JSON</div>
    <h2 class="bb-h2">Variables de diseño</h2>
    <p class="text-base leading-relaxed max-w-2xl" style="color: rgba(31, 31, 29, 0.7);">
      Tokens en formato W3C Design Tokens + Style Dictionary. Importables a
      Figma via Tokens Studio plugin. El archivo canónico está en
      <code class="text-sm px-1.5 py-0.5 rounded" style="background: rgba(31, 43, 56, 0.08);">design-system/tokens.json</code>.
    </p>

    <div class="mt-8 rounded-2xl border p-6" style="border-color: #E4D8C8; background: #fff;">
      <h3 class="type-label mb-4">Color tokens</h3>
      <div class="token-row">
        <div class="token-name">color/cream</div>
        <div class="token-value">#F3EEE6 · bg principal (80%)</div>
        <div class="token-type">color</div>
      </div>
      <div class="token-row">
        <div class="token-name">color/sand</div>
        <div class="token-value">#E4D8C8 · bg secundario, bordes</div>
        <div class="token-type">color</div>
      </div>
      <div class="token-row">
        <div class="token-name">color/charcoal</div>
        <div class="token-value">#1F1F1D · texto principal</div>
        <div class="token-type">color</div>
      </div>
      <div class="token-row">
        <div class="token-name">color/navy</div>
        <div class="token-value">#1F2B38 · acento premium (10%)</div>
        <div class="token-type">color</div>
      </div>
      <div class="token-row">
        <div class="token-name">color/coffee</div>
        <div class="token-value">#4A3525 · iconografía sensorial (5%)</div>
        <div class="token-type">color</div>
      </div>
      <div class="token-row">
        <div class="token-name">color/sage</div>
        <div class="token-value">#6B5E4A · detalles naturales (5%)</div>
        <div class="token-type">color</div>
      </div>
      <div class="token-row">
        <div class="token-name">color/forest <span class="pill-warn pill" style="font-size: 0.5rem; padding: 0.1rem 0.4rem;">EXT</span></div>
        <div class="token-value">#1F3829 · dark mode, hover, footer</div>
        <div class="token-type">color</div>
      </div>
    </div>

    <div class="mt-6 rounded-2xl border p-6" style="border-color: #E4D8C8; background: #fff;">
      <h3 class="type-label mb-4">Typography tokens</h3>
      <div class="token-row">
        <div class="token-name">font/heading</div>
        <div class="token-value">Playfair Display · 400/500/600/700</div>
        <div class="token-type">fontFamily</div>
      </div>
      <div class="token-row">
        <div class="token-name">font/body</div>
        <div class="token-value">Inter · 300/400/500/600/700</div>
        <div class="token-type">fontFamily</div>
      </div>
      <div class="token-row">
        <div class="token-name">size/hero</div>
        <div class="token-value">clamp(3rem, 10vw, 12rem)</div>
        <div class="token-type">fontSize</div>
      </div>
      <div class="token-row">
        <div class="token-name">size/h1</div>
        <div class="token-value">clamp(2.25rem, 5vw, 4rem)</div>
        <div class="token-type">fontSize</div>
      </div>
      <div class="token-row">
        <div class="token-name">letterSpacing/display</div>
        <div class="token-value">-0.05em</div>
        <div class="token-type">letterSpacing</div>
      </div>
      <div class="token-row">
        <div class="token-name">letterSpacing/tracked</div>
        <div class="token-value">0.2em (uppercase labels)</div>
        <div class="token-type">letterSpacing</div>
      </div>
    </div>

    <div class="mt-6 rounded-2xl border p-6" style="border-color: #E4D8C8; background: #fff;">
      <h3 class="type-label mb-4">Motion + Elevation</h3>
      <div class="token-row">
        <div class="token-name">motion/fast</div>
        <div class="token-value">150ms</div>
        <div class="token-type">duration</div>
      </div>
      <div class="token-row">
        <div class="token-name">motion/base</div>
        <div class="token-value">200ms</div>
        <div class="token-type">duration</div>
      </div>
      <div class="token-row">
        <div class="token-name">motion/slow</div>
        <div class="token-value">300ms</div>
        <div class="token-type">duration</div>
      </div>
      <div class="token-row">
        <div class="token-name">motion/standard</div>
        <div class="token-value">cubic-bezier(0.4, 0, 0.2, 1)</div>
        <div class="token-type">cubicBezier</div>
      </div>
      <div class="token-row">
        <div class="token-name">elevation/hairline</div>
        <div class="token-value">0 1px 0 #E4D8C8</div>
        <div class="token-type">boxShadow</div>
      </div>
      <div class="token-row">
        <div class="token-name">elevation/soft</div>
        <div class="token-value">0 2px 8px rgba(31, 27, 22, 0.04)</div>
        <div class="token-type">boxShadow</div>
      </div>
    </div>
  </section>

  <!-- STYLE GUIDELINES -->
  <section class="bb-section">
    <div class="bb-eyebrow">Style Guidelines</div>
    <h2 class="bb-h2">Estilo: Exaggerated Minimalism</h2>

    <div class="bb-grid bb-grid-cols-2 mt-8">
      <article class="type-card">
        <div class="type-label">Do</div>
        <ul class="checklist">
