---
---

<section id="hero" class="relative min-h-screen flex flex-col items-center justify-center px-6 md:px-12 overflow-hidden">
  <!-- Atmosphere gradient -->
  <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse 60% 50% at 50% 40%, #F3EEE6 0%, #E4D8C8 100%); opacity: 0.25;"></div>

  <div class="relative max-w-5xl mx-auto text-center flex flex-col items-center">
    <p class="text-coffee/50 text-xs md:text-sm tracking-[0.3em] uppercase mb-14 md:mb-20 font-medium animate-fade-in">
      Café de especialidad
    </p>

    <h1 class="font-serif text-charcoal leading-[0.85] tracking-[-0.04em] mb-8 md:mb-10 animate-fade-in"
        style="font-size: clamp(3.5rem, 12vw, 15rem); font-weight: 700;">
      icónico
    </h1>

    <div class="w-12 md:w-16 h-px bg-coffee/20 mb-10 md:mb-12 animate-fade-in"></div>

    <p class="font-sans text-charcoal/60 text-lg md:text-2xl font-light tracking-[0.06em] mb-14 md:mb-20 max-w-md animate-fade-in-up">
      Specialty Coffee, Made Simple
    </p>

    <p class="text-charcoal/40 text-base md:text-lg max-w-lg leading-relaxed mb-16 md:mb-24 animate-fade-in-up">
      Granos seleccionados de origen, tostados con precisión. Sin pretensiones, sin tecnicismos innecesarios. Solo buen café, hecho fácil.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-fade-in-up">
      <a href="#productos" class="inline-flex items-center gap-2 bg-navy text-cream px-8 py-4 rounded-full text-sm font-medium tracking-wide hover:bg-navy/90 transition-all duration-200 cursor-pointer group">
        Descubrir café
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a href="#contacto" class="inline-flex items-center gap-2 border border-coffee/20 text-coffee px-8 py-4 rounded-full text-sm font-medium tracking-wide hover:border-coffee/40 hover:bg-coffee/[0.03] transition-all duration-200 cursor-pointer">
        Contacto
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <a href="#productos" class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-coffee/30 hover:text-coffee/50 transition-colors duration-200 cursor-pointer animate-bounce">
    <span class="text-[0.625rem] tracking-[0.3em] uppercase">Scroll</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
  </a>
</section>

<style>
  @keyframes fade-in {
    from { opacity: 0; }
    to { opacity: 1; }
  }
  @keyframes fade-in-up {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fade-in 1s ease-out both;
  }
  .animate-fade-in-up:nth-child(4) { animation: fade-in-up 0.9s 0.2s ease-out both; }
  .animate-fade-in-up:nth-child(5) { animation: fade-in-up 0.9s 0.4s ease-out both; }
  .animate-fade-in-up:nth-child(6) { animation: fade-in-up 0.9s 0.6s ease-out both; }
</style>
