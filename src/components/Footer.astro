---
interface Props {
  variant?: 'landing' | 'shop';
}

const { variant = 'landing' } = Astro.props;
const prefix = variant === 'shop' ? '/' : '';
---

<footer class="bg-[#1F3829] text-cream/40 py-20 md:py-24 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <div class="grid md:grid-cols-[2fr_1fr_1fr] gap-12 md:gap-16 mb-16">
      <div>
        <a href="/" class="font-serif text-2xl font-bold text-cream tracking-[-0.03em]">icónico</a>
        <p class="text-sm mt-4 leading-relaxed text-cream/30 max-w-xs">
          Specialty Coffee, Made Simple.<br />
          Café de especialidad sin pretensiones.
        </p>
      </div>

      <div>
        <h4 class="text-cream/60 text-[0.625rem] tracking-[0.3em] uppercase mb-5 font-semibold">Navegación</h4>
        <ul class="space-y-3">
          <li><a href={`${prefix}#hero`} class="text-sm text-cream/30 hover:text-cream/60 transition-colors duration-200">Inicio</a></li>
          <li><a href={`${prefix}#productos`} class="text-sm text-cream/30 hover:text-cream/60 transition-colors duration-200">Productos</a></li>
          <li><a href={`${prefix}#testimonios`} class="text-sm text-cream/30 hover:text-cream/60 transition-colors duration-200">Testimonios</a></li>
          <li><a href={`${prefix}#contacto`} class="text-sm text-cream/30 hover:text-cream/60 transition-colors duration-200">Contacto</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-cream/60 text-[0.625rem] tracking-[0.3em] uppercase mb-5 font-semibold">Contacto</h4>
        <ul class="space-y-3">
          <li class="flex items-center gap-2.5 text-sm text-cream/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
            hola@iconico.cafe
          </li>
          <li class="flex items-center gap-2.5 text-sm text-cream/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            +52 33 5555-0123
          </li>
          <li class="flex items-center gap-2.5 text-sm text-cream/30">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
            Guadalajara, México
          </li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-cream/20 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-cream/20">
        &copy; {new Date().getFullYear()} Icónico. Todos los derechos reservados.
      </p>
      <p class="text-xs text-cream/20">
        Diseñado con intención. Hecho con café.
      </p>
    </div>
  </div>
</footer>
