---
---

<section id="contacto" class="py-32 md:py-40 px-6 md:px-12">
  <div class="max-w-3xl mx-auto">
    <header class="text-center mb-16 md:mb-20">
      <p class="text-coffee/60 text-xs md:text-sm tracking-[0.3em] uppercase mb-6 font-medium">Contacto</p>
      <h2 class="font-serif text-4xl md:text-6xl lg:text-7xl font-bold text-charcoal leading-[1.05] tracking-[-0.02em]">
        Hablemos<br /><span class="text-navy">de café</span>
      </h2>
      <p class="text-charcoal/50 text-base md:text-lg max-w-md mx-auto mt-8 leading-relaxed">
        ¿Dudas, sugerencias o simplemente quieres charlar? Escríbenos.
      </p>
      <div class="w-12 h-px bg-coffee/20 mx-auto mt-8"></div>
    </header>

    <form
      id="contact-form"
      class="space-y-5"
      method="POST"
      action="/api/contact"
    >
      <div class="grid sm:grid-cols-2 gap-5">
        <div>
          <label for="name" class="block text-xs text-charcoal/50 tracking-[0.2em] uppercase mb-2 font-medium">Nombre</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            class="w-full px-5 py-3.5 bg-cream border border-sand/50 rounded-xl text-charcoal text-sm placeholder:text-charcoal/20 focus:outline-none focus:border-navy/40 focus:ring-1 focus:ring-navy/10 transition-all duration-200"
            placeholder="Tu nombre"
          />
        </div>
        <div>
          <label for="email" class="block text-xs text-charcoal/50 tracking-[0.2em] uppercase mb-2 font-medium">Email</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            class="w-full px-5 py-3.5 bg-cream border border-sand/50 rounded-xl text-charcoal text-sm placeholder:text-charcoal/20 focus:outline-none focus:border-navy/40 focus:ring-1 focus:ring-navy/10 transition-all duration-200"
            placeholder="tu@email.com"
          />
        </div>
      </div>
      <div>
        <label for="message" class="block text-xs text-charcoal/50 tracking-[0.2em] uppercase mb-2 font-medium">Mensaje</label>
        <textarea
          id="message"
          name="message"
          rows="5"
          required
          class="w-full px-5 py-3.5 bg-cream border border-sand/50 rounded-xl text-charcoal text-sm placeholder:text-charcoal/20 focus:outline-none focus:border-navy/40 focus:ring-1 focus:ring-navy/10 transition-all duration-200 resize-none"
          placeholder="Cuéntanos qué necesitas..."
        ></textarea>
      </div>
      <div class="pt-4 text-center">
        <button
          type="submit"
          class="inline-flex items-center gap-2 bg-navy text-cream px-10 py-4 rounded-full text-sm font-medium tracking-wide hover:bg-navy/90 transition-all duration-200 cursor-pointer group"
        >
          Enviar mensaje
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform duration-200"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </button>
      </div>
    </form>

    <div id="form-success" class="hidden text-center py-4">
      <div class="inline-flex items-center gap-2 text-sage text-sm font-medium">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
        Gracias por tu mensaje. Te responderemos pronto.
      </div>
    </div>
    <div id="form-error" class="hidden text-center py-4">
      <p class="text-red-400 text-sm">Algo salió mal. Intenta de nuevo más tarde.</p>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success')!;
  const error = document.getElementById('form-error')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);
    try {
      const res = await fetch('/api/contact', {
        method: 'POST',
        body: data,
      });
      if (res.ok) {
        form.classList.add('hidden');
        success.classList.remove('hidden');
      } else {
        error.classList.remove('hidden');
      }
    } catch {
      error.classList.remove('hidden');
    }
  });
</script>
