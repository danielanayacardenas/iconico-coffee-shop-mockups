---
---

<section id="productos" class="py-32 md:py-40 px-6 md:px-12">
  <div class="max-w-7xl mx-auto">
    <header class="text-center mb-20 md:mb-28">
      <p class="text-coffee/60 text-xs md:text-sm tracking-[0.3em] uppercase mb-6 font-medium">Productos</p>
      <h2 class="font-serif text-4xl md:text-6xl lg:text-7xl font-bold text-charcoal leading-[1.05] tracking-[-0.02em]">
        Elige tu camino<br /><span class="text-navy">con el café</span>
      </h2>
      <div class="w-12 h-px bg-coffee/20 mx-auto mt-8 md:mt-10"></div>
    </header>

    <!-- Tier 1: Para empezar -->
    <section class="mb-24 md:mb-32">
      <div class="text-center mb-12 md:mb-16">
        <span class="inline-block bg-sand/40 text-coffee/80 text-[0.625rem] tracking-[0.3em] uppercase px-5 py-2 rounded-full font-medium">
          Para empezar
        </span>
        <h3 class="font-serif text-3xl md:text-4xl font-bold text-charcoal mt-6 leading-tight">El café del día a día</h3>
      </div>

      <div class="grid md:grid-cols-3 gap-6 md:gap-8">
        <article class="group bg-cream border border-navy/20 rounded-2xl p-8 md:p-10 hover:border-navy/40 transition-all duration-300 cursor-pointer flex flex-col">
          <div class="w-14 h-14 rounded-2xl bg-coffee/[0.06] flex items-center justify-center mb-6 group-hover:bg-coffee/[0.10] text-coffee group-hover:text-navy transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" x2="6" y1="2" y2="4"/><line x1="10" x2="10" y1="2" y2="4"/><line x1="14" x2="14" y1="2" y2="4"/></svg>
          </div>
          <h4 class="font-serif text-2xl font-bold text-charcoal group-hover:text-navy mb-3">Casa</h4>
          <p class="text-charcoal/50 group-hover:text-navy text-sm leading-relaxed mb-6 flex-1">Nuestro blend insignia. Equilibrado, dulce y fácil de preparar. Ideal para espresso y filtrados.</p>
          <div class="flex items-center justify-between pt-5 border-t border-sand/30">
            <span class="text-charcoal group-hover:text-navy font-semibold text-lg">$14.500</span>
            <span class="text-xs text-coffee/50 group-hover:text-navy tracking-wide uppercase">250g</span>
          </div>
        </article>

        <article class="group bg-cream border border-navy/20 rounded-2xl p-8 md:p-10 hover:border-navy/40 transition-all duration-300 cursor-pointer flex flex-col">
          <div class="w-14 h-14 rounded-2xl bg-sage/[0.06] flex items-center justify-center mb-6 group-hover:bg-sage/[0.10] text-sage group-hover:text-navy transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
          </div>
          <h4 class="font-serif text-2xl font-bold text-charcoal group-hover:text-navy mb-3">Suscripción mensual</h4>
          <p class="text-charcoal/50 group-hover:text-navy text-sm leading-relaxed mb-6 flex-1">Recibe nuestro blend Casa todos los meses, sin pensar. Cancela cuando quieras.</p>
          <div class="flex items-center justify-between pt-5 border-t border-sand/30">
            <span class="text-charcoal group-hover:text-navy font-semibold text-lg">$12.800<span class="text-xs text-charcoal/40 group-hover:text-navy/40 font-normal ml-0.5">/mes</span></span>
            <span class="text-xs text-sage group-hover:text-navy font-medium tracking-wide uppercase">+ beneficios</span>
          </div>
        </article>

        <article class="group bg-cream border border-navy/20 rounded-2xl p-8 md:p-10 hover:border-navy/40 transition-all duration-300 cursor-pointer flex flex-col">
          <div class="w-14 h-14 rounded-2xl bg-navy/[0.06] flex items-center justify-center mb-6 group-hover:bg-navy/[0.10] transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1F3829" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="14" x="2" y="5" rx="2"/><line x1="2" x2="22" y1="10" y2="10"/></svg>
          </div>
          <h4 class="font-serif text-2xl font-bold text-charcoal group-hover:text-navy mb-3">Pack regalo</h4>
          <p class="text-charcoal/50 group-hover:text-navy text-sm leading-relaxed mb-6 flex-1">Casa + un método de preparación simple. El regalo perfecto para quien quiere empezar.</p>
          <div class="flex items-center justify-between pt-5 border-t border-sand/30">
            <span class="text-charcoal group-hover:text-navy font-semibold text-lg">$18.900</span>
            <span class="text-xs text-navy/50 group-hover:text-navy tracking-wide uppercase">desde</span>
          </div>
        </article>
      </div>
    </section>

    <!-- Divider -->
    <div class="flex items-center justify-center gap-6 mb-24 md:mb-32">
      <div class="h-px flex-1 bg-navy/20"></div>
      <div class="w-1 h-1 rounded-full bg-navy/20"></div>
      <div class="h-px flex-1 bg-navy/20"></div>
    </div>

    <!-- Tier 2: Coffee lovers -->
    <section class="mb-24 md:mb-32">
      <div class="text-center mb-12 md:mb-16">
        <span class="inline-block bg-navy/[0.06] text-navy/80 text-[0.625rem] tracking-[0.3em] uppercase px-5 py-2 rounded-full font-medium">
          Para coffee lovers
        </span>
        <h3 class="font-serif text-3xl md:text-4xl font-bold text-charcoal mt-6 leading-tight">Experiencias de origen</h3>
      </div>

      <div class="grid md:grid-cols-3 gap-6 md:gap-8">
        <article class="group bg-cream border border-navy/20 rounded-2xl p-8 md:p-10 hover:border-navy/40 transition-all duration-300 cursor-pointer flex flex-col">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-[0.625rem] tracking-[0.2em] uppercase text-navy/70 font-medium bg-navy/[0.06] px-2.5 py-1 rounded">Origen único</span>
            <span class="text-xs text-charcoal/30 group-hover:text-navy/30">Etiopía</span>
          </div>
          <h4 class="font-serif text-2xl font-bold text-charcoal group-hover:text-navy mb-3">Yirgacheffe</h4>
          <p class="text-charcoal/50 group-hover:text-navy text-sm leading-relaxed mb-4 flex-1">Notas a jazmín, limón y miel. Proceso lavado. Tostado claro para preservar acidez brillante.</p>
          <div class="flex flex-wrap gap-1.5 mb-5">
            <span class="text-[0.625rem] text-sage/70 group-hover:text-navy/70 bg-sage/[0.06] px-2 py-0.5 rounded-full">floral</span>
            <span class="text-[0.625rem] text-sage/70 group-hover:text-navy/70 bg-sage/[0.06] px-2 py-0.5 rounded-full">cítrico</span>
            <span class="text-[0.625rem] text-sage/70 group-hover:text-navy/70 bg-sage/[0.06] px-2 py-0.5 rounded-full">dulce</span>
          </div>
          <div class="flex items-center justify-between pt-5 border-t border-sand/30">
            <span class="text-charcoal group-hover:text-navy font-semibold text-lg">$19.800</span>
            <span class="text-xs text-coffee/50 group-hover:text-navy tracking-wide uppercase">250g</span>
          </div>
        </article>

        <article class="group bg-cream border border-navy/20 rounded-2xl p-8 md:p-10 hover:border-navy/40 transition-all duration-300 cursor-pointer flex flex-col">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-[0.625rem] tracking-[0.2em] uppercase text-navy/70 font-medium bg-navy/[0.06] px-2.5 py-1 rounded">Origen único</span>
            <span class="text-xs text-charcoal/30 group-hover:text-navy/30">Colombia</span>
          </div>
          <h4 class="font-serif text-2xl font-bold text-charcoal group-hover:text-navy mb-3">Huila</h4>
          <p class="text-charcoal/50 group-hover:text-navy text-sm leading-relaxed mb-4 flex-1">Notas a chocolate, caramelo y frutos rojos. Tostado medio. Cuerpo sedoso y final limpio.</p>
          <div class="flex flex-wrap gap-1.5 mb-5">
            <span class="text-[0.625rem] text-sage/70 group-hover:text-navy/70 bg-sage/[0.06] px-2 py-0.5 rounded-full">achocolatado</span>
            <span class="text-[0.625rem] text-sage/70 group-hover:text-navy/70 bg-sage/[0.06] px-2 py-0.5 rounded-full">caramelo</span>
            <span class="text-[0.625rem] text-sage/70 group-hover:text-navy/70 bg-sage/[0.06] px-2 py-0.5 rounded-full">frutos rojos</span>
          </div>
          <div class="flex items-center justify-between pt-5 border-t border-sand/30">
            <span class="text-charcoal group-hover:text-navy font-semibold text-lg">$21.200</span>
            <span class="text-xs text-coffee/50 group-hover:text-navy tracking-wide uppercase">250g</span>
          </div>
        </article>

        <article class="group bg-cream border border-navy/20 rounded-2xl p-8 md:p-10 hover:border-navy/40 transition-all duration-300 cursor-pointer flex flex-col">
          <div class="flex items-center gap-2 mb-4">
            <span class="text-[0.625rem] tracking-[0.2em] uppercase text-navy/70 font-medium bg-navy/[0.06] px-2.5 py-1 rounded">Edición limitada</span>
          </div>
          <h4 class="font-serif text-2xl font-bold text-charcoal group-hover:text-navy mb-3">Selección del mes</h4>
          <p class="text-charcoal/50 group-hover:text-navy text-sm leading-relaxed mb-4 flex-1">Origen rotativo cada mes. Una experiencia nueva en cada bolsa. Notas de cata incluidas.</p>
          <div class="flex items-center justify-between pt-5 border-t border-sand/30">
            <span class="text-charcoal group-hover:text-navy font-semibold text-lg">$23.500</span>
            <span class="text-xs text-navy/50 group-hover:text-navy tracking-wide uppercase">suscripción</span>
          </div>
        </article>
      </div>
    </section>

    <!-- Gamification -->
    <div class="relative overflow-hidden bg-sand/20 rounded-3xl p-10 md:p-16 text-center">
      <div class="max-w-3xl mx-auto relative">
        <span class="inline-block bg-sage/[0.10] text-sage/80 text-[0.625rem] tracking-[0.3em] uppercase px-5 py-2 rounded-full font-medium mb-6">
          Programa Icónico
        </span>
        <h3 class="font-serif text-3xl md:text-5xl font-bold text-charcoal mb-4 leading-tight">El café te devuelve</h3>
        <p class="text-charcoal/50 text-base leading-relaxed mb-12 max-w-lg mx-auto">
          Cada compra suma puntos. Cada punto te acerca a más café.
        </p>

        <div class="grid sm:grid-cols-3 gap-8 md:gap-10 mb-10">
          <div class="flex flex-col items-center gap-3">
            <div class="w-12 h-12 rounded-2xl bg-coffee/[0.06] flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#6B4F3A" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5C7 4 7 7 7 7"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5C18 4 18 7 18 7"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2Z"/></svg>
            </div>
            <span class="text-charcoal font-semibold text-sm">Catas gratis</span>
            <span class="text-charcoal/40 text-xs leading-relaxed">Eventos mensuales<br />para socios</span>
          </div>
          <div class="flex flex-col items-center gap-3">
            <div class="w-12 h-12 rounded-2xl bg-navy/[0.06] flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#1F3829" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </div>
            <span class="text-charcoal font-semibold text-sm">Envíos gratis</span>
            <span class="text-charcoal/40 text-xs leading-relaxed">En pedidos desde<br />$15.000</span>
          </div>
          <div class="flex flex-col items-center gap-3">
            <div class="w-12 h-12 rounded-2xl bg-sage/[0.06] flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7C8063" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
            </div>
            <span class="text-charcoal font-semibold text-sm">Sorteos</span>
            <span class="text-charcoal/40 text-xs leading-relaxed">Equipos y ediciones<br />especiales</span>
          </div>
        </div>

        <div class="inline-flex flex-wrap items-center justify-center gap-x-5 gap-y-1 text-[0.625rem] text-charcoal/30 tracking-[0.2em] uppercase font-medium">
          <span>1 compra = 10 pts</span>
          <span class="text-sand/60 select-none">·</span>
          <span>Catas = 50 pts</span>
          <span class="text-sand/60 select-none">·</span>
          <span>Envío = 100 pts</span>
          <span class="text-sand/60 select-none">·</span>
          <span>Sorteos = 200 pts</span>
        </div>
      </div>
    </div>
  </div>
</section>
